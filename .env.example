# Squeaky Clean Koh Samui — Environment Variables
# Copy to .env.local and fill in values for development

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Omise (Opn Payments) ===
# Awaiting merchant approval — leave blank until approved
NEXT_PUBLIC_OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=

# === Google Maps ===
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# === Google Calendar (Service Account) ===
# Base64-encoded JSON key file for the service account
GOOGLE_CALENDAR_SERVICE_ACCOUNT=

# === Resend (Email) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@squeakycleansamui.com

# === Twilio (WhatsApp + SMS) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# === PostHog (Analytics) ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# === Google Tag Manager ===
NEXT_PUBLIC_GTM_ID=

# === App Config ===
NEXT_PUBLIC_SITE_URL=https://squeakycleansamui.com
NEXT_PUBLIC_DEFAULT_LOCALE=en
